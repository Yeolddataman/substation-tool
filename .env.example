# ── Copy this file to .env and fill in your values ──────────────────────

# Authentication — generate hash + JWT secret by running: npm run setup-creds
AUTH_USERNAME=TestUser
AUTH_PASSWORD_HASH=                   # bcrypt hash (never store plaintext)
JWT_SECRET=                           # 48-byte random hex, generated by setup-creds

# Optional: override default server port (default: 3001)
# PORT=3001

# NERDA — SSEN Near Real-Time Data Access API
# Long-term key: generated at https://nerda.ssen.co.uk (valid 90 days)
# Username: the email address registered with the NERDA portal
NERDA_API_KEY=
NERDA_USERNAME=

# Note: No Anthropic API key needed here.
# Each user provides their own key in the AI assistant UI.
# It is sent per-request via HTTPS — never stored server-side.
